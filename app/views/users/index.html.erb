<div class="user_info">
  <h2>User info</h2>

  <% @users.each do |user| %>

  <div class="user_image">
    <% if user.profile_image.attached? %>
      <%= image_tag user.profile_image %>
    <% else %>
      <%= image_tag "default-image.jpg" %>
    <% end %>
  </div>

<% end %>

<div class=new_book>
 <h2>New book</h2>
 <%= form_with model:Book.new do |f| %>
   <h4>Title</h4>
   <%= f.text_field :title %>
   <h4>Opinion</h4>
   <%= f.text_area :body %>
   <%=f.submit "Create Book" %>
 <% end %>  
</div>

<div class="users">
  <h2>Users</h2>

  <table>
     <tr>
      <th>image</th>
      <th>name</th>
      <th>action</th>
     </tr> 
     

  <% @users.each do |user| %>
    <tr>

     <td>
      <% if user.profile_image.attached? %>
        <%= image_tag user.profile_image %>
      <% else %>
        <%= image_tag "default-image.jpg" %>
      <% end %>
     </td>
    
     <td> 
      <p><%= user.name %></p>
     </td>

     <td>
      <%= link_to "Show", user_path(user) %>
     </td>
     
     </tr>

  <% end %>
   </table>  
</div>
 