<p id="notice"></p>
 <div class="container">
  <div class="row">
   <div class="col-sm-12 col-md-8 col-lg-5 px-5 px-sm-0 mx-auto">

<% if @user.errors.any? %>
  <%= pluralize(@user.errors.count, "error") %> prohibited this obj from being saved:
  <ul>
   <% @user.errors.full_messages.each do |message| %>
    <li><%= message %></li>
   <% end %>
  </ul>
<% end %>

<h2>User info</h2>

<%= form_with model: @user do |f| %>
 
 <div class="form-group mb-3">
  <%= f.label :name,"Name" %>
  <%= f.text_field :name,class: "form-control" %>
 </div>
 
 <div class="form-group mb-3">
  <%= f.label :profile_image, "Image",class: "form-label d-block" %>
  <%= f.file_field :profile_image,class: "form-control-file" %>
 </div> 

 <div class="form-group mb-3">
  <%= f.label :introduction, "Introduction" %>
  <%= f.text_area :introduction,class: "form-control" %>
 </div>

 <div class="form-group mb-3">
  <%= f.submit "Update User",class: "btn btn-secondary" %>
 </div>

<% end %>

  </div>
 </div>
</div>
