
<div class=user_info>
 <h2>User info</h2>
 
 <div class="user_image">
  <% if @user.profile_image.attached? %>
    <%= image_tag @user.profile_image %>
  <% else %>
    <%= image_tag "default-image.jpg" %>
  <% end %>
 </div>
 
 <p>name</p>
 <span><%= @user.name %></span>

 <p>introduction</p>
 <span><%= @user.introduction %></span>

 <%= link_to "Edit Profile",edit_user_path(@user) %>
</div>

<div class=new_book>
 <h2>New book</h2>
 <%= form_with model:Book.new do |f| %>
   <h4>Title</h4>
   <%= f.text_field :title %>
   <h4>Opinion</h4>
   <%= f.text_area :body %>
   <%=f.submit "Create Book" %>
 <% end %>  
</div>

<div class=books>
 <h2>Books</h2>

 <table>
 <tr>
  <th>Title</th>
  <th>Opinion</th>
 <tr>

 <% @books.each do |book| %>
<tr>
  <td>
  <% if book.user.profile_image.attached? %>
   <%= image_tag book.user.profile_image %>
  <% else %>
   <%= image_tag "default-image.jpg" %>
  <% end %> 
  </td>
  <td><%= link_to book.title,book_path(book) %></td>
  <td><%= book.body %></td>
</tr>
 <% end %>
</table>  
</div>  