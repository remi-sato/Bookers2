
<div class="container px-5 px-sm-0">
 <div class="row">

  <div class="col-md-3">
 
  <h2>User info</h2>
  <div class="user_image">
  <% if @user.profile_image.attached? %>
    <%= image_tag @user.profile_image ,size:"80x80"  %>
  <% else %>
    <%= image_tag "default-image.jpg" ,size:"80x80" %>
  <% end %>
 </div>
 
 <table class="table">
  <tbody>
  <tr>
   <th>name</th>
   <th><%= @user.name %></th>
  </tr> 

  <tr>
   <th>introduction</th>
   <th><%= @user.introduction %></th>
  </tr>
  </tbody>
 </table>

   <%= link_to edit_user_path(@user), class: "btn btn-outline-secondary btn-block edit_user_#{@user.id}" do %>
   <i class="fa-solid fa-user-gear"></i>
   <% end %>

<h2 class="mt-3">New book</h2>

 <%= form_with model:Book.new do |f| %>
  <div class="form-group">
   <%= f.label :title, "Title" %>
   <%= f.text_field :title,class: "form-control book_title" %>
  </div>
  <div class="form-group">
   <%= f.label :body, "Opinion" %> 
   <%= f.text_area :body,class: "form-control book_body" %>
  </div>
  <div class="form-group mt-3"> 
   <%=f.submit "Create Book",class: "btn btn-success" %>
  </div> 
 <% end %>  

 </div>

<div class="col-md-8 offset-md-1">
 <h2>Groups</h2>

 <table class="table">
  <thead>
   <tr>
    <th></th>
    <th>グループ名</th>
    <th>紹介文</th>
    <th>メンバー数</th>
   </tr>
  </thead>
  <tbody>
   <% @groups.each do |group| %>
   <tr>
    <td>
     <% if group.group_image.attached? %>
      <%= image_tag group.group_image.variant(resize_to_limit: [80,80]) %>
     <% else %>
      <%= image_tag "default-image.jpg", size: "80x80" %>
     <% end %>
    </td>
    <td>
     <%= link_to group.name, group_path(group) %>
    </td>
    <td>
     <%= group.introduction %>
    </td>
    <td>
     <%= group.group_users.count %>
    </td>
     <td>
     <% if group.owner_id.to_i == current_user.id %>
      <%= link_to "Edit",edit_group_path(group), class: "btn btn-success text-white" %>
     <% end %>
    </td>
   </tr>
   <% end %>
  </tbody>
 </table>
</div>
