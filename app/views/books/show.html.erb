<% if @book.errors.any? %> 
 <%=pluralize(@book.errors.count,"error") %> prohibited this obj from being saved: 
  <ul> <% @book.errors.full_messages.each do |message| %> 
    <li><%= message %></li> <% end %> 
  </ul>
<% end %>

<p id ="notice"></p>

<div class="container px-5 px-sm-0">
 <div class="row">

  <div class="col-md-3">
 
  <h2>User info</h2>
  <div class="user_image">
  <% if @book.user.profile_image.attached? %>
    <%= image_tag @book.user.profile_image ,size:"80x80"  %>
  <% else %>
    <%= image_tag "default-image.jpg" ,size:"80x80" %>
  <% end %>
 </div>
 
 <table class="table">
  <tbody>
  <tr>
   <th>name</th>
   <th><%= @book.user.name %></th>
  </tr> 

  <tr>
   <th>introduction</th>
   <th><%= @book.user.introduction %></th>
  </tr>
  </tbody>
 </table>

  <div class="row">
   <% if @book.user == current_user %>
    <%= link_to edit_user_path(current_user), class: "btn btn-outline-secondary btn-block edit_user_#{current_user.id}" do %>
     <i class="fa-solid fa-user-gear"></i>
    <% end %>
   <% else %>
    <%= link_to edit_user_path(@book.user), class: "btn btn-outline-secondary btn-block edit_user_#{current_user.id}" do %>
    <i class="fa-solid fa-user-gear"></i>
   <% end %>
  <% end %>
  </div>
 

<h2 class="mt-3">New book</h2>
 <%= form_with model:Book.new do |f| %>
  <div class="form-group">
   <%= f.label :title, "Title" %>
   <%= f.text_field :title,class: "form-control book_title" %>
  </div>
  <div class="form-group">
   <%= f.label :body, "Opinion" %> 
   <%= f.text_area :body,class: "form-control book_body" %>
  </div>
  <div class="form-group mt-3"> 
   <%=f.submit "Create Book",class: "btn btn-success" %>
  </div> 
 <% end %>  
 </div> 


<div class="col-md-8 offset-md-1">
 <h2>Book detail</h2>
 
 <table class="table">
  <tbody>
   <tr>
   <td>
    <%= link_to user_path(@book.user) do %>

    <% if @book.user.profile_image.attached? %>
     <%= image_tag @book.user.profile_image, size: "80x80" %>
    <% else %>
     <%= image_tag "default-image.jpg", size: "80x80" %>
    <% end %>
    <br>
     <%= @book.user.name %>
    <% end %>
  </td>
    <td>
     <%= @book.title %>
    </td>
    <td>
     <%= @book.body %>
    </td>

   <% if @book.user == current_user %>
    <td>
     <%= link_to "Edit", edit_book_path(@book),class: "btn btn-sm btn-success edit_book_#{@book.id}" %>
    </td>
    <td> 
     <%= link_to "Destroy", book_path(@book), data:{ turbo_method: :delete, turbo_confirm:"本当に消しますか？"},class: "btn btn-sm btn-danger destroy_book_#{@book.id}" %>
    </td> 
   <% end %>

   <td>
  <% if @book.favorited_by?(Current.user) %>
   <p>
    <%= link_to book_favorites_path(@book),data: {turbo_method: :delete} do %>
     ♥<%= @book.favorites.count %>
    <% end %>
   </p>
  <% else %>
   <p>  
    <%= link_to book_favorites_path(@book),data: {turbo_method: :post} do %>
     ♡<%= @book.favorites.count %>
    <% end %>
   </p>
  <% end %>   
  </td>
  <td>
   <p>コメント数：<%= @book.book_comments.count %></p>
  </td>
  </tr>
 </tbody>
 </table>

 <table class="table">
  <tbody>
    <% @book.book_comments.each do |book_comment| %>
      <tr>
        <td style="border: none;">
          <%= link_to user_path(book_comment.user) do %>
            <% if book_comment.user.profile_image.attached? %>
              <%= image_tag book_comment.user.profile_image, size: "80x80" %>
            <% else %>
              <%= image_tag "default-image.jpg", size: "80x80" %>
            <% end %>
            <br>
            <%= book_comment.user.name %>
          <% end %>
        </td>

        <td style="vertical-align: middle; border: none;">
          <%= book_comment.comment %>
        </td>

        <td style="vertical-align: middle; border: none;">
          <% if book_comment.user == current_user %>
            <%= link_to "Destroy", book_book_comment_path(book_comment.book, book_comment), data: { turbo_method: :delete }, class: "btn btn-sm btn-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="form-group mt-3">
  <%= form_with model: [@book, @book_comment] do |f| %>
    <%= f.text_area :comment, rows: 5, class: "form-control" %>
    <%= f.submit "送信", class: "btn btn-light border mt-2" %>
  <% end %>
</div>